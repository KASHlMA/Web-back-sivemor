MYSQL_DATABASE=sivemor
MYSQL_USER=sivemor
MYSQL_PASSWORD=sivemor
MYSQL_ROOT_PASSWORD=rootpassword

BACKEND_PORT=8080
WEB_ADMIN_PORT=3000

JWT_SECRET=this-is-a-long-jwt-secret-value-at-least-thirty-two-characters
JWT_ISSUER=sivemor-platform
JWT_ACCESS_TOKEN_MINUTES=60
JWT_REFRESH_TOKEN_DAYS=14

CORS_ALLOWED_ORIGIN=http://localhost:3000
APP_MAIL_ENABLED=false
APP_MAIL_FROM=no-reply@sivemor.local
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_PROTOCOL=smtp
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS=false
MAIL_SMTP_SSL_ENABLE=false
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000
APP_MAIL_ALLOW_TEST_INBOX=false
